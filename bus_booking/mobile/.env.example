# Django API base (no trailing slash). Optional in dev: the app tries to infer your PC's IP
# from Metro (`http://<that-ip>:8000`). Set this to override, or for release builds.
#
# Examples:
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
#   EXPO_PUBLIC_API_URL=https://api.yourdomain.com
#
# Start Django so other devices can connect:
#   python manage.py runserver 0.0.0.0:8000
EXPO_PUBLIC_API_URL=
