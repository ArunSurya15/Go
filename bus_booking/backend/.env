# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get your API key at https://resend.com → Add API Key
# Free tier: 3,000 emails/month, 100/day. No credit card needed.
RESEND_API_KEY=re_8i8vJoPp_4hkxhrEzJqrfTSMZNBF2WTAY
# Once you verify your domain on Resend, replace with e.g. "e-GO <noreply@yourdomain.com>"
EMAIL_FROM=e-GO Tickets <onboarding@resend.dev>
# Base URL of your frontend (used in ticket links in emails)
APP_BASE_URL=http://localhost:3000

# ── SMS ────────────────────────────────────────────────────────────────────────
# Set SMS_PROVIDER=twilio or msg91 to enable booking confirmation SMS.
# Twilio: reuses TWILIO_* keys below. Buy a number at twilio.com (~$1/month).
# MSG91: get auth key at msg91.com. Requires DLT template registration for India.
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=EGOBKS
MSG91_BOOKING_TEMPLATE_ID=

# ── WhatsApp ───────────────────────────────────────────────────────────────────
# Set to 'twilio' or 'meta'. Leave blank to disable.
WHATSAPP_PROVIDER=
# Twilio: reuses TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN from SMS section above.
# Your Twilio WhatsApp sender (sandbox: whatsapp:+14155238886, live: your approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Meta Cloud API (alternative to Twilio, cheaper at scale)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=